# ---- Aggregator hub config ----

# Port the hub listens on (browsers connect here over ONE WebSocket).
PORT=8080

# ---- Default source targets (can also be changed live from the UI) ----

# Twitch channel login name (no leading #). Example: xqc
TWITCH_CHANNEL=xqc

# Kick channel slug (the part after kick.com/). Example: trainwreckstv
KICK_CHANNEL=trainwreckstv

# X / Twitter search query. Mentions of a handle work well.
# Examples: "@nasa", "@nasa -is:retweet", "from:nasa"
X_QUERY=@nasa -is:retweet

# ---- X / Twitter API (pay-as-you-go) ----
# Bearer token for the X API v2. NEVER hardcode this in source.
# Get one at https://developer.x.com. Leave blank to disable the X source.
X_BEARER_TOKEN=

# How often to poll the X recent-search endpoint, in milliseconds (>=12000 recommended).
X_POLL_INTERVAL_MS=12000

# ---- Kick Pusher (defaults usually work; override only if Kick changes them) ----
KICK_PUSHER_KEY=32cbd69e4b950bf97679
KICK_PUSHER_CLUSTER=us2

# Kick sits behind Cloudflare. The server resolves the chatroom id via `curl
# --http1.1` (passes the TLS fingerprint check that Node's fetch fails). If your
# host has no curl or Cloudflare blocks it anyway, set the chatroom id manually
# here to skip the lookup. Find it at kick.com/api/v2/channels/{slug} -> chatroom.id
KICK_CHATROOM_ID=
